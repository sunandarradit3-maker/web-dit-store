generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PromptStatus {
  FREE
  VIP
}

enum MediaType {
  PHOTO
  FILE
}

model Prompt {
  id        String       @id @default(cuid())
  title     String
  category  String
  content   String       @db.Text
  tutorial  String       @db.Text
  status    PromptStatus @default(FREE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([status])
  @@index([category])
}

model Media {
  id        String    @id @default(cuid())
  title     String
  filename  String
  url       String    @db.Text
  type      MediaType
  size      Int?
  mimeType  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([type])
}

model VipAccessLog {
  id        String   @id @default(cuid())
  userHash  String?
  createdAt DateTime @default(now())

  @@index([createdAt])
}
